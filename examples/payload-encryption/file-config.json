{
  "nats": {
    "url": "nats://localhost:4222",
    "stream": "ORDERS",
    "consumer": "encrypted-file-orders-sink",
    "subject": "orders.*",
    "durable": true
  },
  "delivery": {
    "batch_size": 100,
    "batch_timeout_ms": 1000,
    "ack_policy": "after_sink_commit",
    "temporary_failure_action": "nak",
    "prefer_safe_duplication": true
  },
  "logging": {
    "level": "INFO",
    "payload_logging": false
  },
  "message_metadata": {
    "priority": {
      "header": "Nats-Sinks-Priority",
      "default": "routine"
    },
    "classification": {
      "header": "Nats-Sinks-Classification",
      "default": "NATO UNCLASSIFIED"
    },
    "labels": {
      "header": "Nats-Sinks-Labels",
      "default": "encrypted;local-test"
    }
  },
  "encryption": {
    "enabled": true,
    "algorithm": "aes-256-gcm",
    "key_id": "local-example-key",
    "key_b64_env": "NATS_SINKS_PAYLOAD_KEY_B64",
    "nonce_size_bytes": 12,
    "tag_length": 16
  },
  "sink": {
    "type": "file",
    "directory": ".local/file-sink/encrypted-events",
    "filename_strategy": "stream_sequence",
    "duplicate_policy": "skip_existing",
    "payload_mode": "json_or_envelope",
    "compression": "none",
    "fsync": true
  }
}
